generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  username     String?  @unique
  name          String?
  image         String?
  bio           String?
  favoriteGame String?
  country      String?
  isPro        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  settings     Setting[]
  history      History[]
}

model Setting {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       String
  dpi         Int
  sensitivity Float
  edpi        Int
  cm360       Float
  mouseGrip  String?
  aimStyle   String?
  isCurrent  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model History {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       String
  dpi         Int
  sensitivity Float
  edpi        Int
  cm360       Float
  createdAt   DateTime @default(now())

  @@index([userId])
}